{
  "name": "archworkspace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "predev": "node scripts/sync-ports.js",
    "dev": "vite",
    "dev:full": "node scripts/sync-ports.js && powershell -File scripts/start.ps1",
    "dev:python": "powershell -File scripts/service_manager.ps1 start-be",
    "dev:python:clean": "powershell -File scripts/service_manager.ps1 restart",
    "dev:api": "cd server && npm install && node server.js",
    "sync:ports": "node scripts/sync-ports.js",
    "postinstall": "node scripts/sync-ports.js",
    "pretest:e2e": "node scripts/sync-ports.js",
    "build": "vite build",
    "analyze": "vite build && echo Bundle analysis: stats.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "node scripts/sync-ports.js && playwright test",
    "test:all": "npm run test:run && npm run test:e2e",
    "electron:dev": "set VITE_DEV_SERVER_URL=http://localhost:3004 && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron .",
    "deploy:vercel": "vercel --prod",
    "lint:style": "stylelint \"src/**/*.{css,scss,vue}\"",
    "lint:style:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@mermaid-js/layout-elk": "^0.2.1",
    "echarts": "^5.5.1",
    "element-plus": "^2.14.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "mermaid": "^11.13.0",
    "modern-normalize": "^3.0.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.1",
    "playwright": "1.60.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.69.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-scss": "^6.14.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "build": {
    "appId": "com.archworkspace.app",
    "productName": "ArchWorkspace",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
