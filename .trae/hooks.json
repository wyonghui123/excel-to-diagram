{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$p = $env:TRAE_PROJECT_DIR; if (-not $p) { $p = (Get-Location).Path }; & (Join-Path $p 'scripts\\debug\\session_start_bootstrap.ps1')\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
