{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"& 'd:\\filework\\excel-to-diagram\\scripts\\debug\\session_start_bootstrap.ps1'\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"$input | & 'd:\\filework\\excel-to-diagram\\scripts\\debug\\hooks_pre_tool_use.ps1'\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}