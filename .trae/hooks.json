{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/debug/utils/session_start_bootstrap.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "RunCommand",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/debug/utils/_pre_tool_hook.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}