# Trae 代码索引忽略规则
# 补充 .gitignore，控制 #Workspace / #Folder 搜索范围

# === Dependencies ===
node_modules/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# === Build output ===
dist/
release/

# === Trae internal (大量 spec/state 文件，不需要 AI 搜索) ===
.trae/specs/
.trae/state/
.trae/skills/

# === Test artifacts ===
test_output/
test_results/
_browser_sessions/

# === Runtime ===
logs/
*.err
*.out
*.jsonl

# === Database ===
*.db
*.db-shm
*.db-wal
*.architecture.lock

# === Uploads ===
uploads/
exports/

# === Debug scripts (临时文件) ===
_*.py
_*.ps1
diag-*.ps1
commit_msg.txt

# === Archive ===
archive/
_archive_*/

# === IDE auto-generated ===
auto-imports.d.ts
components.d.ts

# === Coverage ===
stats.html
_meta/
coverage/
