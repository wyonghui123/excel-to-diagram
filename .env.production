# Production Environment Configuration
# Copy this file to .env and update values for production deployment

# JWT Secret Key - MUST be changed for production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY_AT_LEAST_32_CHARS

# Flask port
FLASK_PORT=3010

# [FR-024] CORS 白名单 (逗号分隔, 生产环境必须配置)
# 未配置 + FLASK_DEBUG=false → 所有跨域请求被拒绝
CORS_ALLOWED_ORIGINS=https://your-production-domain.com
