# ===== v3.19 新增：调试残留 + DB 监控日志 =====
# 调试脚本 (root 目录)
test_dim_scope_debug*.py
check_*.py
debug_*.py
probe_*.py
*.dbg/

# ===== v2026.06.21: 调试基础设施例外 =====
# scripts/debug/check_*.py 是基础设施工具（必须入仓）
# 只有 root 目录下的 check_*.py 才被忽略
!/scripts/debug/check_*.py
!/scripts/debug/inspect/check_*.py

# DB 监控日志 (运行时生成, 每天数十MB, 不应入仓)
meta/db_monitor_logs/
*.jsonl

# stats & debug 报告
stats.html
_meta/

# 临时文件 (调试过程产生)
*.tmp.log
tmp_*.py
head_*.py
list_*.py

# Git 恢复工作区 (本会话创建)
.git-recovery/


# ===== v3.22: Runtime artifacts (added 2026-06-20) =====
# Service runtime logs
logs/*.err
logs/*.out

# DB backups (created by watchdog/health monitor)
meta/architecture.db.backup_*
meta/architecture.db.backup_archive_*

# Test artifact archives (date-stamped folders)
_archive_*/

# Test uploads (one-off Excel files for import testing)
uploads/*.xlsx
!uploads/.gitkeep

# ===== v3.23: IDE auto-generated type declarations =====
# Auto-generated by Volar / unplugin-vue-components
auto-imports.d.ts
components.d.ts

# ===== v3.24: Debug residue (AI Agent ad-hoc temp files) =====
# Avoid pollution from one-off debug scripts and screenshots dumped at repo root
/_*.py
/_*.txt
/_*.png
/_*.jpg
/_*.patch
/_*.bat
/_*.json
/_*.log
/_*.html

# ===== v3.25: Session cookies + backend debug residue =====
cookies.txt

# Backend code & DB backups (created by hot-patch scripts)
**/*.bak
**/*.bak_*
**/*.pre_*
meta/architecture.db.pre_*

# Backend log files at multiple levels
/backend.err
/backend.out
/backend-test.err
/backend-test.out
/meta/backend.err
/meta/backend.out
/scripts/logs/*.err
/scripts/logs/*.out
/scripts/logs/

# One-shot debug scripts in scripts/debug/ (~200 files)
/scripts/debug/

# Test artifacts
/test_temp/
/test_output/
/test_helpers/screenshots/

# IDE/agent runtime state
.startup_state.json
.trae/debug/

# Ad-hoc auto-commit / restart batch scripts
/commit_v35p5.bat
/重启后端.bat

# ===== v3.26: Remaining debug residue =====

# meta/ 下的临时调试脚本 (与 /_*.py 对应)
/meta/_*.py
/meta/_*.txt
/meta/_*.log
/meta/_*.patch

# meta/logs/ 运行时日志目录 (与 /scripts/logs/ 平行)
/meta/logs/

# scripts/ 下的 .trae/ (与 root .trae/debug/ 平行)
/scripts/.trae/

# scripts/ 下的临时验证脚本 (与 root check_*.py / debug_*.py 对应)
/scripts/verify_*.py
/scripts/probe_*.py
/scripts/list_*.py

