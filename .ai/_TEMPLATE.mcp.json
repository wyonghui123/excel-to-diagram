{
  "_template_version": "0.1.0",
  "_template_description": "MCP 配置文件模板(工具无关)。使用前请复制到 .ai/mcp.json 并填写。",
  "_schema_doc": "https://modelcontextprotocol.io/docs/concepts/architecture",
  "mcpServers": {
    "<server-name>": {
      "command": "<command>",
      "args": ["<arg1>", "<arg2>"],
      "env": {
        "<ENV_VAR>": "<value>"
      },
      "capabilities": [
        "<capability-1>",
        "<capability-2>"
      ],
      "disabled": false,
      "comment": "填写 server 说明,首次启用需 review"
    }
  }
}