# 服务端口配置
# 使用 npm run dev:full 启动所有服务

# 前端开发服务器端口
VITE_DEV_PORT=3004

# Node.js Mock API 服务器端口
MOCK_API_PORT=3001

# Python Flask 后端端口
FLASK_PORT=5000

# E2E 测试服务器端口
E2E_PORT=3004

# API 代理配置（指向 Python 后端）
VITE_API_PROXY=http://localhost:5000

# Mock API 代理配置
VITE_MOCK_API_PROXY=http://localhost:3001

# ============================================
# 敏感配置（请复制到 .env 文件中填写真实值）
# 注意：.env 文件已在 .gitignore 中，不会被提交
# ============================================

# JWT Secret Key (生产环境必须修改!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY_AT_LEAST_32_CHARS

# [FR-024] CORS 白名单 (逗号分隔)
CORS_ALLOWED_ORIGINS=http://localhost:3004,http://127.0.0.1:3004

# DeepSeek API配置
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 智谱AI API配置
VITE_ZHIPU_API_KEY=your_zhipu_api_key_here

# 飞书开放平台配置
VITE_FEISHU_APP_ID=your_feishu_app_id_here
VITE_FEISHU_APP_SECRET=your_feishu_app_secret_here
VITE_FEISHU_ACCESS_TOKEN=your_feishu_access_token_here
